<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>macRo</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.utilities</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSHumanReadableCopyright</key>
	<string>Copyright © 2026 626 Labs LLC. All rights reserved.</string>

	<!-- ============================================================
	     .macro bundle UTI declaration
	     A .macro is a folder (Mac idiom) that Finder treats as a
	     single document via LSItemContentTypes + UTExportedTypeDeclarations.
	     CLI / file system see it as a directory.
	     Spec ref: design spec § 4 (the .macro bundle format).
	     ============================================================ -->

	<!-- CFBundleDocumentTypes deliberately omitted in v1.
	     Registering macRo as document handler for the com.626labs.macro
	     UTI made LaunchServices + SwiftUI WindowGroup treat the entire
	     main window as a drop receiver — drop cursor over interactive
	     elements, clicks intercepted (the wizard's Continue button
	     stopped firing). The "Finder double-click a .macro to open in
	     macRo" path is item 9 territory (Library import); re-add this
	     block then with a scoped CFBundleTypeRole ("Viewer") and a
	     drop-target-aware EditorView. The UTExportedTypeDeclarations
	     below stays — that just declares the UTI exists; it does not
	     enable drop-targeting. -->

	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.626labs.macro</string>
			<key>UTTypeDescription</key>
			<string>macRo Macro Bundle</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.directory</string>
				<string>com.apple.package</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>macro</string>
				</array>
			</dict>
		</dict>
	</array>

	<!-- Permission usage strings — required entitlements land in
	     macRo.entitlements; these strings explain the asks to the user.
	     The full entitlements wizard is checklist item 3. -->
	<key>NSScreenCaptureUsageDescription</key>
	<string>macRo records the Roblox window so you can edit gameplay into a macro.</string>
</dict>
</plist>
